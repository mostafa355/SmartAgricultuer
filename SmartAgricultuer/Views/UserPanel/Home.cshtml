@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = "_UserPanelLayout";
}
@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true">
}

<div class="page-content">
    <div class="home-container">
        <div class="home-text">
            <h1>AI Plant</h1>
            <h1>Disease</h1>
            <h1 class="detection">Detection</h1>
        </div>
        <div class="home-image">
            <img src="~/imeges/unnamed.png" alt="Plant AI">
        </div>
    </div>

    <!-- Cards Section -->
    <div class="section-wrapper">
        <div class="section-container">
            <div class="section-content">
                <h1>Advanced Botanical Analysis</h1>
            </div>

            <div class="cards-container">
                <div class="card">
                    <div class="card-icon-circle">
                        <span class="material-symbols-outlined" style="font-size:40px; color:#006400;">bolt</span>
                    </div>
                    <h2>Instant Analysis</h2>
                    <p>Upload photos and get diagnostics in under 3 seconds using our edge computing.</p>
                </div>

                <div class="card">
                    <div class="card-icon-circle">
                        <span class="material-symbols-outlined" style="font-size:40px; color:#006400;">spa</span>
                    </div>
                    <h2>Treatment Plans</h2>
                    <p>Receive detailed guides, recommended fertilizers, and organic cures for your plants.</p>
                </div>

                <div class="card">
                    <div class="card-icon-circle">
                        <span class="material-symbols-outlined" style="font-size:40px; color:#006400;">analytics</span>
                    </div>
                    <h2>Crop Monitoring</h2>
                    <p>Historical health tracking and local environment analysis via satellite data.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="cta-container">
            <span class="cta-decor-circle circle-1"></span>
            <span class="cta-decor-circle circle-2"></span>
            <span class="cta-decor-circle circle-3"></span>
            <span class="cta-decor-circle circle-4"></span>
            <span class="cta-decor-circle circle-5"></span>

            <h2>Ready to heal your plants?</h2>
            <p>Upload a photo of your plant and get an instant AI-powered health analysis with care tips!</p>
            <button class="cta-btn" id="startUploadBtn">Start Upload</button>
        </div>
    </section>
</div>