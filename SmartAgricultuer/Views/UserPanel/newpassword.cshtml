@{
    // إلغاء الـ Layout تماماً لتصبح الصفحة مستقلة
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Change Password</title>

    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <link rel="stylesheet" href="~/css/newpassword.css" asp-append-version="true">
</head>
<body>

    <div class="main-wrapper">
        <div class="password-box">
            <div class="icon-header">
                <span class="material-symbols-outlined">lock_reset</span>
            </div>
            <h2>Change Password</h2>
            <p>Please enter your current and new password to update your account security.</p>

            <form id="passwordForm">
                <div class="input-field">
                    <label>Old Password</label>
                    <input type="password" id="currentPass" required placeholder="Enter current password">
                </div>

                <div class="input-field">
                    <label>New Password</label>
                    <input type="password" id="newPass" required placeholder="Enter new password">
                </div>

                <div class="input-field">
                    <label>Confirm New Password</label>
                    <input type="password" id="confirmPass" required placeholder="Re-type new password">
                </div>

                <button type="submit" class="btn-update">Update Password</button>
            </form>

            <a asp-controller="UserPanel" asp-action="Home" class="link-back">Back to Home</a>
        </div>
    </div>

    <script src="~/js/newpassword.js" asp-append-version="true"></script>

</body>
</html>