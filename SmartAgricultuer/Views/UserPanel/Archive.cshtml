*@
@{
    Layout = "_UserPanelLayout";
}
@section Styles {
    <link rel="stylesheet" href="~/css/Archive.css" asp-append-version="true">
}

<div class="history-page">
    <header class="topbar">
        Botanical Encyclopedia
    </header>

    <div class="hero">
        <h1>Plants & Insects Guide</h1>
        <p>
            Browse comprehensive information about crop types, their characteristics, and the insects and pests that affect them.
        </p>
    </div>

    <div class="filter-controls">
        <button class="filter-btn active" onclick="filterCards('all')">All </button>
        <button class="filter-btn" onclick="filterCards('plant')">Plants</button>
        <button class="filter-btn" onclick="filterCards('insect')">Insects</button>
    </div>

    <div class="cards-grid">

        @if (ViewBag.Plants != null)
        {
            foreach (var plant in ViewBag.Plants)
            {
                <div class="card filter-item plant">
                    <img src="~/@plant.ImageUrl" alt="@plant. Name ">
                    <div class="card-content">
                        <div class="card-header">
                            <h3>@plant.Name </h3>
                        </div>
                        <p><strong>Description:</strong> @plant.Description</p>

                        <div class="extra-info">
                            <p>Common Diseases:<strong>@plant.CommonDiseases </strong></p>
                            <p><strong>GeneralCare :</strong> @plant.GeneralCare</p>
                        </div>

                        <div class="status plant-badge">Plant</div>
                    </div>
                </div>
            }
        }

        @if (ViewBag.Insects != null)
        {
            foreach (var insect in ViewBag.Insects)
            {
                <div class="card filter-item insect">
                    <img src="~/@insect.ImageUrl" alt="@insect.Name">
                    <div class="card-content">
                        <div class="card-header">
                            <h3>@insect.Name</h3>
                        </div>
                        <p><strong>Description:</strong> @insect.Description</p>

                        <div class="extra-info">
                           
                            <p>
                                Status: <strong>@insect.Status</strong>
                            </p>
                            <p><strong>Prevention:</strong> @insect.Prevention</p>
                        </div>

                        <div class="status insect-badge">Insect</div>
                    </div>
                </div>
            }
        }

    </div>

@section Scripts {
    <script>
        function filterCards(category) {
            var cards = document.querySelectorAll('.filter-item');

            cards.forEach(function(card) {
                if (category === 'all' || card.classList.contains(category)) {
                    card.style.display = 'flex'; // استخدام flex للحفاظ على تناسق الكارت
                } else {
                    card.style.display = 'none';
                }
            });

            var buttons = document.querySelectorAll('.filter-btn');
            buttons.forEach(function(btn) {
                btn.classList.remove('active');
            });
            event.currentTarget.classList.add('active');
        }
    </script>
}