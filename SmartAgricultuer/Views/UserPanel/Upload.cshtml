@{
    Layout = "_UserPanelLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/upload.css" asp-append-version="true">
}
<main class="content">
    <div class="main-wrapper">
        <div class="upload-card">
            <h1>Diagnose Your Plant's Health</h1>
            <p class="subtitle">
                Upload a clear photo of the affected leaves for an instant AI analysis and recovery plan.
            </p>

            <!-- Toggle تحت النص مباشرة -->
            <div class="toggle-wrapper">
                <label class="custom-switch">
                    <input type="checkbox">
                    <div class="slider">
                        <span class="text plant">Plant</span>
                        <span class="text insect">Insect</span>
                        <div class="knob"></div>
                    </div>
                </label>
            </div>

            <div class="upload-area">
                <input type="file" id="fileInput" accept="image/png, image/jpeg" hidden>
                <div id="uploadIcon" class="upload-icon-circle">
                    <span class="material-symbols-outlined">cloud_upload</span>
                </div>
                <h3>Upload Plant Image</h3>
                <p>Drag and drop your image here, or click to browse files</p>
                <small>JPEG, PNG • MAX 10MB</small>
                <br>
                <button id="browseBtn">Browse Files</button>
            </div>

            <div id="filePreviewContainer" class="file-preview hidden">
                <div class="file-preview-inner">
                    <img id="previewImage" src="" alt="preview">
                    <p id="fileName"></p>
                    <span id="removeFile" class="material-symbols-outlined delete-icon">delete</span>
                </div>
            </div>

            <button id="scanBtn" class="scan-btn">
                <span class="material-symbols-outlined">analytics</span> Scan Image
            </button>
            <p id="result" class="result"></p>
        </div>
    </div>
</main>