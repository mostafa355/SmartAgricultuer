@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = "_UserPanelLayout";
}
@section Styles {
    <link rel="stylesheet" href="~/css/result.css" asp-append-version="true">
}


<div class="page-content-wrapper">
    <main class="container">

        <!-- HERO -->
        <section class="hero">
            <div class="hero-image">
                <img src="~/imeges/image1.png" alt="Tomato leaf infected with early blight">
            </div>

            <div class="hero-text">
                <h1>Diagnosis: Early Blight</h1>
                <p>
                    Our AI analyzed your sample with 98.4% confidence. This fungal infection requires prompt
                    treatment to prevent spread.
                </p>

                <div class="confidence-container">
                    <div class="confidence-info">
                        <span class="confidence-label">AI CONFIDENCE SCORE</span>
                        <span class="confidence-value">98.4%</span>
                    </div>

                    <div class="progress-bar-bg">
                        <div class="progress-bar-fill" style="width: 98.4%;"></div>
                    </div>

                    <p class="confidence-note small">High reliability based on visual leaf patterns</p>
                </div>
            </div>
        </section>

        <!-- MAIN GRID -->
        <div class="main-grid">

            <!-- LEFT -->
            <div class="left-column">

                <!-- PLANT INFO -->
                <div class="card plant-info">
                    <div class="card-header">
                        <span class="material-symbols-outlined icon-green">potted_plant</span>
                        <h2>Plant Information</h2>
                    </div>

                    <div class="plant-details">

                        <div class="stats-side">
                            <label>COMMON NAME</label>
                            <p class="bold">Tomato</p>

                            <label>SCIENTIFIC NAME</label>
                            <p class="italic small">Solanum lycopersicum</p>

                            <label>GENERAL CARE</label>
                            <ul class="care-list">
                                <li>
                                    <span class="material-symbols-outlined">water_drop</span> Regular watering at
                                    base
                                </li>
                                <li>
                                    <span class="material-symbols-outlined">wb_sunny</span> Full sun (6–8 hours)
                                </li>
                                <li><span class="material-symbols-outlined">eco</span> Nutrient-rich soil</li>
                            </ul>
                        </div>

                        <div class="description-side">
                            <label>DESCRIPTION</label>
                            <p class="small">
                                A widely cultivated plant known for its edible fruits. Tomatoes are rich in
                                nutrients and commonly used in many cuisines worldwide.
                            </p>
                        </div>

                    </div>
                </div>

                <!-- TREATMENT -->
                <div class="protocol-section">
                    <div class="card-header">
                        <span class="material-symbols-outlined icon-green">medical_services</span>
                        <h2>Treatment Protocol</h2>
                    </div>

                    <div class="protocol-grid">

                        <div class="step-card">
                            <div class="step-num">1</div>
                            <h3>Remove infected leaves</h3>
                            <p class="small">Carefully prune affected leaves using sterilized tools.</p>
                        </div>

                        <div class="step-card">
                            <div class="step-num">2</div>
                            <h3>Apply fungicide</h3>
                            <p class="small">
                                Use a copper-based fungicide following the recommended instructions.
                            </p>
                        </div>

                        <div class="step-card">
                            <div class="step-num">3</div>
                            <h3>Improve soil health</h3>
                            <p class="small">Ensure proper drainage, rotate crops, and avoid overhead watering.</p>
                        </div>

                    </div>
                </div>

                <!-- SAFETY -->
                <div class="card horizontal-safety">
                    <div class="card-header">
                        <span class="material-symbols-outlined">security</span>
                        <h2>Safety Profile</h2>
                    </div>

                    <div class="safety-content">
                        <p class="bold">Tomato</p>

                        <div class="scientific-row">
                            <p class="italic small">Solanum lycopersicum</p>
                            <span class="tag-harmful">HARMFUL</span>
                        </div>

                        <p class="safety-desc small">
                            Leaves and stems contain alkaloids that may be toxic if consumed.
                        </p>

                        <div class="safety-tips-grid">
                            <div class="tip-box">
                                <span class="material-symbols-outlined icon-red">pets</span>
                                Keep away from pets
                            </div>

                            <div class="tip-box">
                                <span class="material-symbols-outlined icon-green">clean_hands</span>
                                Wash hands after handling
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- SIDEBAR -->
            <aside class="result-info-sidebar">

                <!-- DISEASE -->
                <div class="card disease-profile">
                    <div class="card-header">
                        <span class="material-symbols-outlined icon-red">coronavirus</span>
                        <h2>Disease Profile</h2>
                    </div>

                    <div class="profile-content">
                        <label>DISEASE</label>
                        <p class="bold">Early Blight</p>

                        <label>CAUSATIVE AGENT</label>
                        <p class="italic small">Alternaria solani</p>

                        <label>KEY SYMPTOMS</label>
                        <p class="small">
                            Circular brown or black spots with yellow halos on leaves.
                        </p>

                        <div class="prevention-note">
                            <label>PREVENTION</label>
                            <p class="small">
                                Avoid overhead watering and maintain good airflow between plants.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- STATUS -->
                <div class="card healthy-profile">
                    <div class="card-header">
                        <span class="material-symbols-outlined icon-red">warning</span>
                        <h2>Plant Health Status</h2>
                    </div>

                    <div class="profile-content">
                        <label>CURRENT STATUS</label>
                        <p class="bold">Infected</p>

                        <label>OBSERVATIONS</label>
                        <p class="small">
                            Visible lesions and discoloration detected on leaves.
                        </p>

                        <div class="maintenance-note">
                            <label>RECOMMENDATION</label>
                            <p class="small">
                                Follow treatment steps immediately to prevent disease spread.
                            </p>
                        </div>
                    </div>
                </div>

            </aside>

        </div>
    </main>
</div>