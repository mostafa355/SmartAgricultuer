@using SmartAgriculture.ViewModels
@model DiseaseResultViewModel
@{
    Layout = "_UserPanelLayout";
}
@section Styles {
    <link rel="stylesheet" href="~/css/result.css" asp-append-version="true">
}


<div class="page-content-wrapper">
    <main class="container">

        <!-- HERO -->
        <section class="hero">
            <div class="hero-image">
                <img src="@Model.imgurl" alt="Tomato leaf infected with early blight">
            </div>

            <div class="hero-text">
                <h1>@(ViewBag.IsInsect ? "The discovered insect" : "Plant and disease"): @Model.DiseaseName</h1>
                <p>
                    Our AI analyzed your sample with @Model.Confidence% confidence. This fungal infection requires prompt
                    treatment to prevent spread.
                </p>

                <div class="confidence-container">
                    <div class="confidence-info">
                        <span class="confidence-label">AI CONFIDENCE SCORE</span>
                        <span class="confidence-value">@Model.Confidence%</span>
                    </div>

                    <div class="progress-bar-bg">
                        <div class="progress-bar-fill" style="width: @Model.Confidence%;"></div>
                    </div>

                    <p class="confidence-note small">High reliability based on visual leaf patterns</p>
                </div>
            </div>
        </section>

        <!-- MAIN GRID -->
        <div class="main-grid">

            <!-- LEFT -->
            <div class="left-column">

                <!-- PLANT INFO -->
                <div class="card plant-info">
                    <div class="card-header">
                        <span class="material-symbols-outlined icon-green">potted_plant</span>
                        <h2>Plant Information</h2>
                    </div>

                    <div class="plant-details">

                        <div class="stats-side">
                            <label>COMMON NAME</label>
                            <p class="bold">@Model.PlantName</p>

                            <label>SCIENTIFIC NAME</label>
                            <p class="italic small">@Model.ScientificName</p>

                            <label>GENERAL CARE</label>
                            <p class="small">
                                @Model.GeneralCare
                            </p>
                        </div>

                        <div class="description-side">
                            <label>DESCRIPTION</label>
                            <p class="small">
                                @Model.PlantDescription
                            </p>
                        </div>

                    </div>
                </div>

                <!-- TREATMENT -->
                @if (Model.TreatmentSteps != null && Model.TreatmentSteps.Count > 0)
                {
                <div class="protocol-section">
                    <div class="card-header">
                        <span class="material-symbols-outlined icon-green">medical_services</span>
                        <h2>Treatment Protocol</h2>
                    </div>

                    <div class="protocol-grid">
                        @foreach (var step in Model.TreatmentSteps)
                        {
                            <div class="step-card">
                                <div class="step-num">@step.StepNumber</div>
                                <h3>@step.StepTitle</h3>
                                <p class="small">@step.StepDescription</p>
                            </div>
                        }
                    </div>
                </div>
                } 

                <!-- SAFETY -->
                <div class="card horizontal-safety">
                    <div class="card-header">
                        <span class="material-symbols-outlined">security</span>
                        <h2>Safety Profile</h2>
                    </div>

                    <div class="safety-content">
                        <p class="bold">@Model.PlantName</p>

                        <div class="scientific-row">
                            <p class="italic small">@Model.ScientificName</p>
                        </div>


                        <div class="safety-tips-grid">
                            <div class="tip-box">
                                <span class="material-symbols-outlined icon-red">pets</span>
                                Keep away from pets
                            </div>

                            <div class="tip-box">
                                <span class="material-symbols-outlined icon-green">clean_hands</span>
                                Wash hands after handling
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- SIDEBAR -->
            <aside class="result-info-sidebar">

                <!-- DISEASE -->
                <div class="card disease-profile">
                    <div class="card-header">
                        <span class="material-symbols-outlined icon-red">coronavirus</span>
                        <h2>Disease Profile</h2>
                    </div>

                    <div class="profile-content">
                        <label>DISEASE</label>
                        <p class="bold">@Model.DiseaseName</p>

                        <label>CAUSATIVE AGENT</label>
                        <p class="italic small">@Model.Causes</p>

                        <label>KEY SYMPTOMS</label>
                        <p class="small">
                            @Model.Symptoms
                        </p>

                        <div class="prevention-note">
                            <label>PREVENTION</label>
                            <p class="small">
                                @Model.Prevention
                            </p>
                        </div>
                    </div>
                </div>

                <!-- STATUS -->
                <div class="card healthy-profile">
                    <div class="card-header">
                        <span class="material-symbols-outlined icon-red">warning</span>
                        <h2>Plant Health Status</h2>
                    </div>

                    <div class="profile-content">
                        <label>CURRENT STATUS</label>
                        <p class="bold">@(Model.DetectionStatus != "NULL" ? Model.DetectionStatus : "Not Harmful")</p>

                        <div class="maintenance-note" style="border-left: 4px solid @if (Model.DetectionStatus == "Critical") { <text>#f44336</text> } else if (Model.DetectionStatus == "Moderate") { <text>#ff9800</text> } else if (Model.DetectionStatus == "Low") { <text>#ffc107</text> } else { <text>#166534</text> };">
                            <label>RECOMMENDATION</label>
                            @if (Model.DetectionStatus == "Critical")
                            {
                                <pre class="small">
Follow treatment steps immediately to prevent disease spread.
Remove and destroy severely infected plant parts immediately.
Apply emergency treatment and consult a specialist urgently.
Consider quarantining the plant to protect your entire garden.
                                </pre>
                            }
                            else if (Model.DetectionStatus == "Moderate")
                            {
                            <pre class="small">
Follow treatment steps immediately to prevent disease spread.
Apply recommended fungicide or pesticide as directed.
Improve air circulation around the plant immediately.
Reduce watering frequency and avoid wetting the foliage.
                            </pre>
                            }
                            else if (Model.DetectionStatus == "Low")
                            {
                            <pre class="small">
Follow treatment steps immediately to prevent disease spread.
Isolate the affected plant from others to avoid contamination.
Remove any visibly infected leaves or stems carefully.
Monitor daily for any progression of symptoms.
                                </pre>
                            }
                            else
                            {
                            <pre class="small">
Your plant is healthy! Keep up the good care routine.
Continue regular watering and monitoring for any changes.
Maintain proper sunlight exposure and fertilization schedule.
Check weekly to ensure optimal growing conditions.
                                </pre>
                            }
                        </div>
                    </div>
                </div>

            </aside>

        </div>
    </main>
</div>
