@{
    ViewData["Title"] = "Home Page";
}

<section class="home" id="home">
    <div class="home-bg">
        <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuCdM-UsJe0af9LtRoE9p-ASBYo6KDvUl96Xk7EMixSBYslS2gbPu92uWRbj6XGVAdMfIWITu9fwDv3IMlurHqn5XH18m7g5w9hPlFLbafR82XOdYQyQGk6493llrYTxv0vF2ieTT4U2fcyBlgHnSbS6vO_qAZyoo013b1YV44BLuvhF2F0n5oTLnh0g53iIIuZRc98VTjwcHZhXq-Ieker4hEpAX_4UjDHZHnRNINag_xiYq56XOHdqkBcD4_EM332WCtu0Yp8GNru4" alt="Agricultural field background" />
        <div class="home-bg-overlay"></div>
    </div>
    <div class="home-content">
        <h1>
            Plant Disease <span class="text-primary">Detection System</span>
        </h1>
        <p>
            Identify plant diseases easily using AI. Protect your crops and maximize your yield with cutting-edge technology.
        </p>
    </div>
</section>

<section class="about" id="about">
    <div class="container grid-two">
        <div class="about-image">
            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAN4S8sN0BP6AXN3d0yCn9YYtjAvQS-yPiYnodzVonaVOfT1um89xGt0_bsSxuEFG2yF4QGPuVZq0P0DaG3B1C89fjqRp2bzy2jtgZiTcDw08sitDUbO1oSGSL_rGF8PY0JKjyG3pcAjK99Nsl8HEOw-gikkNRaHWVMUfu9RxhylLp5EO6azqUUOy-zX7QyEbdLnYsTe5RJFVjH1npqMljhiGbWlWTwMMurB7HLIL0kzhuSxkT3ACvEfWazvVXlBRuiyl9-GQUPrDp3" alt="Leaf analysis" />
            <div class="magnifier">
                <span class="material-symbols-outlined">magnification_small</span>
            </div>
        </div>
        <div class="about-text">
            <h3>About the Website</h3>
            <p>
                Our platform utilizes advanced Computer Vision to perform precise leaf analysis. By training on thousands of images, the system can distinguish between healthy foliage and dozens of common pathogens.
            </p>
            <p>
                This digital tool transforms your smartphone into a portable laboratory, providing instant feedback on the biological status of your crops without the need for physical samples.
            </p>
            <div class="validated">
                <span class="material-symbols-outlined">verified_user</span>
                <span>Based On Trained Ai Models</span>
            </div>
        </div>
    </div>
</section>

<section class="purpose" id="purpose">
    <div class="container text-center">
        <h2>Why This Website?</h2>
        <div class="purpose-box">
            <p class="quote">"Early detection is the most effective weapon against crop failure."</p>
            <p>
                Agriculture faces increasing threats from climate change and emerging pests. Our mission is to democratize early detection, allowing anyone to stop a disease before it spreads across entire fields.
            </p>
            <div class="purpose-grid">
                <div>
                    <span class="material-symbols-outlined">eco</span>
                    <p>Reduce chemical pesticide overuse through targeted treatment.</p>
                </div>
                <div>
                    <span class="material-symbols-outlined">trending_up</span>
                    <p>Increase global food security by protecting small-scale farmers.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="how-it-works" id="how-it-works">
    <div class="container text-center text">
        <h2>3-Step Visual Guide</h2>
        <p>Our simple workflow for rapid results.</p>
        <div class="steps-grid">
            <div class="step">
                <div class="icon-circle"><span class="material-symbols-outlined">cloud_upload</span></div>
                <h4>1. Upload</h4>
                <p>Take a photo of the infected leaf and upload it to our secure portal.</p>
            </div>
            <div class="step">
                <div class="icon-circle"><span class="material-symbols-outlined">memory</span></div>
                <h4>2. AI Analysis</h4>
                <p>Our deep learning model scans for thousands of unique disease markers.</p>
            </div>
            <div class="step">
                <div class="icon-circle"><span class="material-symbols-outlined">fact_check</span></div>
                <h4>3. Results</h4>
                <p>Receive a comprehensive report with diagnosis and action steps.</p>
            </div>
        </div>
    </div>
</section>

<section class="results" id="results">
    <div class="container">
        <div class="text-center">
            <h2>Comprehensive Reports</h2>
            <p>What the system provides after every analysis</p>
        </div>
        <div class="results-grid">
            <div class="card">
                <span class="material-symbols-outlined">potted_plant</span>
                <h5>Plant Type</h5>
                <p>Automated identification of the crop species (e.g., Tomato, Potato, Corn).</p>
            </div>
            <div class="card">
                <span class="material-symbols-outlined">monitor_heart</span>
                <h5>Health Status</h5>
                <p>A clear percentage score of the plant's overall health and vitality.</p>
            </div>
            <div class="card">
                <span class="material-symbols-outlined">coronavirus</span>
                <h5>Disease Name</h5>
                <p>Precise scientific and common name of the detected pathogen.</p>
            </div>
            <div class="card">
                <span class="material-symbols-outlined">healing</span>
                <h5>Treatment</h5>
                <p>Recommended organic and chemical interventions to cure the disease.</p>
            </div>
            <div class="card lg-span-2">
                <span class="material-symbols-outlined">shield</span>
                <h5>Prevention Strategy</h5>
                <p>Long-term advice on soil management, watering cycles, and environmental factors to prevent future outbreaks.</p>
            </div>
        </div>
    </div>
</section>

<section class="features" id="features">
    <div class="container">
        <h2 class="text-center">System Features</h2>
        <div class="features-grid">
            <div class="feature-card">
                <span class="material-symbols-outlined">speed</span>
                <h6>Fast Analysis</h6>
                <p>Get diagnostic results in less than 3 seconds after upload.</p>
            </div>
            <div class="feature-card">
                <span class="material-symbols-outlined">school</span>
                <h6>Educational Info</h6>
                <p>Integrated library of plant diseases and gardening tips.</p>
            </div>
            <div class="feature-card">
                <span class="material-symbols-outlined">history</span>
                <h6>History Log</h6>
                <p>Track the health progress of your plants over time.</p>
            </div>
            <div class="feature-card">
                <span class="material-symbols-outlined">offline_pin</span>
                <h6>Offline Capability</h6>
                <p>Basic detection features available without active internet.</p>
            </div>
        </div>
    </div>
</section>

<section class="users" id="users">
    <div class="container">
        <div class="text-center">
            <h2>Who Is It For?</h2>
            <p>Designed to be accessible to everyone in the agricultural ecosystem.</p>
        </div>
        <div class="users-grid">
            <div class="user-card">
                <span class="material-symbols-outlined">menu_book</span>
                <h4>Students</h4>
                <p>A practical tool for agricultural students to learn disease identification and pathology in the field.</p>
            </div>
            <div class="user-card">
                <span class="material-symbols-outlined">agriculture</span>
                <h4>Farmers</h4>
                <p>Protect your livelihood with instant diagnostics that help save crops and optimize fertilizer use.</p>
            </div>
            <div class="user-card">
                <span class="material-symbols-outlined">yard</span>
                <h4>Beginners</h4>
                <p>New to gardening? Our AI acts as your personal expert guide for a thriving home garden.</p>
            </div>
        </div>
    </div>
</section>

<section class="contact" id="contact">
    <div class="container contact-container">
        <div class="contact-box">
            <div class="contact-info">
                <h2>Get in touch</h2>
                <p>Have questions about our research or need technical support? Send us a message.</p>
                <div class="contact-details">
                    <div class="contact-item">
                        <div class="icon-circle-small">
                            <span class="material-symbols-outlined">mail</span>
                        </div>
                        <div>
                            <p>Support Email</p>
                            <p>support@plantdoc.ai</p>
                        </div>
                    </div>
                    <div class="contact-item">
                        <div class="icon-circle-small">
                            <span class="material-symbols-outlined">school</span>
                        </div>
                        <div>
                            <p>Academic Inquiry</p>
                            <p>research@plantdoc.ai</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>