<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartAgricultuer</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/DS/css/navbar.css" asp-append-version="true">
    <link rel="stylesheet" href="~/DS/css/root.css" asp-append-version="true">
    @RenderSection("Styles", required: false)
</head>
<body>
    <header>
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="header-content">
                    <div class="logo-wrapper">
                        <span class="logo-text">Plant AI</span>
                        <p class="sector-tag">Field Data</p>
                    </div>

                    <button class="menu-toggle" id="menuToggle">
                        <span class="material-symbols-outlined">menu</span>
                    </button>
                </div>
            </div>

            <nav class="nav-menu">
                <a href="analses.html" class="nav-item">
                    <span class="material-symbols-outlined">monitoring</span>
                    <span class="nav-label">Analytics</span>
                </a>

                <div class="nav-dropdown">
                    <a href="#" class="nav-item active" id="tablesToggle">
                        <span class="material-symbols-outlined">table_chart</span>
                        <span class="nav-label">Tables</span>
                        <span class="material-symbols-outlined arrow-icon">expand_more</span>
                    </a>

                    <div class="dropdown-container" id="tablesDropdown">
                        <a href="Insects.html" class="dropdown-item">
                            <span class="material-symbols-outlined">bug_report</span>
                            <span>Insects</span>
                        </a>

                        <a href="table_plant.html" class="dropdown-item">
                            <span class="material-symbols-outlined">potted_plant</span>
                            <span>Plants</span>
                        </a>

                        <a href="Diseases.html" class="dropdown-item">
                            <span class="material-symbols-outlined">coronavirus</span>
                            <span>Diseases</span>
                        </a>
                    </div>
                </div>
            </nav>

            <div class="sidebar-footer">
                <a href="profile.html" class="nav-item">
                    <span class="material-symbols-outlined">account_circle</span>
                    <span class="nav-label">Profile</span>
                </a>

                <a href="login.html" class="nav-item logout-item">
                    <span class="material-symbols-outlined">logout</span>
                    <span class="nav-label">Log Out</span>
                </a>
            </div>
        </aside>
    </header>
    <div class="main">
        @RenderBody()
    </div>

    <footer >
    </footer>

    <script src="~/DS/js/navbar.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
