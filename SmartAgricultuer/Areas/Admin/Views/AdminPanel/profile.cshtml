@{
    ViewData["Title"] = "User Profile";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/DS/css/profile.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/DS/js/profile.js" asp-append-version="true"></script>
}
<div id="navbar-placeholder">
</div>
<header class="topbar">
    <div class="logo">AgriPulse AI</div>

    <div class="top-icons">
        <div class="profile-small">
            <img src="~/DS/images/one.jpg" alt="Profile">
        </div>
    </div>
</header>
<div id="navbar"></div>
<main class="main-profile-content">
    <div class="page-title">
        <h1>User Profile</h1>
        <p>Manage your account settings and preferences.</p>
    </div>

    <div class="grid-layout">
        <div class="card profile-card">
            <img src="~/DS/images/one.jpg" alt="Julian Thorne" />
            <h2>Julian Thorne</h2>
            <p>julian.thorne@agripulse.ai</p>

            <div class="tags">
                <div class="tag">Senior Lead</div>
                <div class="tag">Verification Tech</div>
            </div>

            <div class="stats">
                <div class="stat">
                    <p>Fields Managed</p>
                    <h3>12</h3>
                </div>
                <div class="stat">
                    <p>Reports Filed</p>
                    <h3>148</h3>
                </div>
            </div>
        </div>

        <div class="card settings-card">
            <div class="settings-header">
                <h3>Account Preferences</h3>
            </div>

            <a href="#" onclick="openEditPopup()" class="setting-item">
                <div class="setting-left">
                    <div class="setting-icon">
                        <span class="material-symbols-outlined">edit</span>
                    </div>
                    <div class="setting-text">
                        <h4>Edit Profile</h4>
                        <p>Update your personal details</p>
                    </div>
                </div>
                <span class="material-symbols-outlined">chevron_right</span>
            </a>

            <a href="#" onclick="openPopup()" class="setting-item">
                <div class="setting-left">
                    <div class="setting-icon">
                        <span class="material-symbols-outlined">lock</span>
                    </div>
                    <div class="setting-text">
                        <h4>Change Password</h4>
                        <p>Update your account password securely</p>
                    </div>
                </div>
                <span class="material-symbols-outlined">chevron_right</span>
            </a>

            <div class="setting-item logout">
                <div class="setting-left">
                    <div class="setting-icon">
                        <span class="material-symbols-outlined">logout</span>
                    </div>
                    <div class="setting-text">
                        <h4>Logout</h4>
                        <p>Safely sign out</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<div id="editProfilePopup" class="popup-overlay">
    <div class="popup-box">
        <h2>Edit Profile</h2>
        <form>
            <input type="text" placeholder="Full Name">
            <input type="email" placeholder="Email">
            <input type="password" placeholder="New Password">
            <input type="password" placeholder="Confirm Password">
            <button type="button">Save Changes</button>
        </form>
        <span class="close-btn" onclick="closeEditPopup()">✖</span>
    </div>
</div>

<div id="passwordPopup" class="popup-overlay">
    <div class="popup-box">
        <h2>Change Password</h2>
        <p>Enter your current and new password</p>
        <form>
            <input type="password" placeholder="Old Password">
            <input type="password" placeholder="New Password">
            <input type="password" placeholder="Confirm Password">
            <button type="button">Update Password</button>
        </form>
        <span class="close-btn" onclick="closePopup()">✖</span>
    </div>
</div>