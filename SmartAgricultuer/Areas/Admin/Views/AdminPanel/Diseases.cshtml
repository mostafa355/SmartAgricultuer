@model IEnumerable<SmartAgricultuer.ViewModels.DiseaseTableViewModel>

@{
    ViewData["Title"] = "Disease Page";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/DS/css/Diseases.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/DS/js/Diseases.js" asp-append-version="true"></script>
}

<main class="main-content">

    <header class="page-header">
        <div class="header-text">
            <h1>Manage and monitor plant diseases</h1>
            <p>Access AI-driven diagnosis and historical records for your fields.</p>
        </div>

        <a asp-area="Admin" asp-controller="AdminPanel" asp-action="adddisease" style="text-decoration: none;">
            <button class="btn-primary" id="addDiseaseBtn">
                <span class="material-symbols-outlined">add_circle</span> Add Disease
            </button>
        </a>
    </header>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="icon-box error" style="background: #fef2f2; color: #dc2626;"><span class="material-symbols-outlined">gavel</span></div>
            <div>
                <p class="label">CRITICAL (DESTROY)</p>
                <p class="value" style="color: #dc2626;">@ViewBag.CriticalAlerts</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="icon-box error" style="background: #fff7ed; color: #ea580c;"><span class="material-symbols-outlined">warning</span></div>
            <div>
                <p class="label">MODERATE (CONTAIN)</p>
                <p class="value" style="color: #ea580c;">@ViewBag.ModerateAlerts</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="icon-box success"><span class="material-symbols-outlined">check_circle</span></div>
            <div>
                <p class="label">SAFE / NORMAL</p>
                <p class="value text-success">@ViewBag.LowAndNormal</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="icon-box primary"><span class="material-symbols-outlined">monitoring</span></div>
            <div>
                <p class="label">TOTAL PATHOGENS</p>
                <p class="value" style="color: var(--primary);">@ViewBag.TotalPathogens</p>
            </div>
        </div>
    </div>

    <div class="search-container">
        <div class="search-box">
            <span class="material-symbols-outlined search-icon">search</span>
            <input type="text" id="diseaseSearch" onkeyup="filterDiseasesTable()" placeholder="Search by disease name, plant type, or ID...">
        </div>
    </div>

    <div class="table-wrapper">
        <table id="diseaseTable">
            <thead>
                <tr>
                    <th>Disease ID</th>
                    <th>Disease Name</th>
                    <th>Plant Type</th>
                    <th>Symptoms</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" style="text-align:center; color:#64748b; padding: 20px;">No diseases found in database</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        string statusClass = "";
                        string statusText = "";

                        if (item.Status == "High" || item.Status == "Critical")
                        {
                            statusClass = "status-dangerous";
                            statusText = "Critical";
                        }
                        else if (item.Status == "Moderate")
                        {
                            statusClass = "status-medium";
                            statusText = "Moderate";
                        }
                        else if (item.Status == "Low")
                        {
                            statusClass = "status-healthy";
                            statusText = "Low Risk";
                        }
                        else
                        {
                            statusClass = "status-healthy";
                            statusText = "Normal";
                        }

                        <tr>
                            <td style="font-family: monospace; color:#94a3b8;">#DIS-@item.Id.ToString("D4")</td>
                            <td>
                                <div class="disease-info">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@Url.Content("~/" + item.ImageUrl)" class="table-thumb-img" alt="@item.Name">
                                    }
                                    else
                                    {
                                        <div class="table-thumb-placeholder">🦠</div>
                                    }
                                    <span style="color:#002d1c;">@item.Name</span>
                                </div>
                            </td>
                            <td>@item.PlantType</td>
                            <td title="@item.Symptoms">
                                @(item.Symptoms.Length > 40 ? item.Symptoms.Substring(0, 40) + "..." : item.Symptoms)
                            </td>
                            <td>
                                <span class="status-pill @statusClass">@statusText</span>
                            </td>
                            <td class="text-right" style="position: relative;">
                                <div class="action-menu">
                                    <button class="btn-action-trigger" onclick="toggleDropdown(event, 'dropdown-@item.Id')">
                                        <span class="material-symbols-outlined">more_vert</span>
                                    </button>
                                    <div class="dropdown" id="dropdown-@item.Id" style="display:none; position:absolute; right:0; z-index:10;">
                                        <a asp-action="EditDisease" asp-route-id="@item.Id" style="text-decoration:none; color:inherit;">
                                            <button type="button">Edit</button>
                                        </a>
                                        <a asp-action="DeleteDisease" asp-route-id="@item.Id" onclick="return confirm('Are you sure you want to delete this disease?')" style="text-decoration:none; color:inherit;">
                                            <button type="button" class="btn-delete">Delete</button>
                                        </a>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        <div class="table-footer">
            <span id="entryCount">Loading entries...</span>
            <div class="pagination" id="paginationWrapper">
            </div>
        </div>
    </div>

    <div class="bottom-grid">
        <div class="prevention-card">
            <h3><span class="material-symbols-outlined">verified_user</span> Suggested Prevention Strategies</h3>
            <div class="strategy-item">
                <span class="material-symbols-outlined">psychology</span>
                <div>
                    <h4>Crop Rotation (Interval: 3 Years)</h4>
                    <p>Rotate Solanaceae crops with cereals or legumes to disrupt pathogen life cycles.</p>
                </div>
            </div>
            <div class="strategy-item">
                <span class="material-symbols-outlined">water_drop</span>
                <div>
                    <h4>Precision Irrigation Control</h4>
                    <p>Avoid overhead watering during high-humidity cycles to minimize leaf moisture.</p>
                </div>
            </div>
        </div>

        <div class="ai-card">
            <h3>AI Diagnostic Insights</h3>
            <p>Real-time analysis suggests weather patterns (High Humidity + 22°C) increase risk by 45%.</p>
            <button class="btn-light">Run Risk Assessment</button>
        </div>
    </div>
</main>