@{
   ViewData["Title"] = "Add Insect Page";
}
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}
@section Styles {
    <link rel="stylesheet" href="~/DS/css/Add plant.css" asp-append-version="true" />
}
@section Scripts {
    <script src="~/DS/js/Add plant.js" asp-append-version="true"></script>
}
<div class="main-wrapper">
    <main class="content">
        <div class="form-container">
            <div class="header-section">
                <div>
                    <h2 class="section-title">Add New Plant</h2>
                    <p class="section-subtitle">Enter plant information and agricultural care details for precision monitoring.</p>
                </div>
            </div>

            <div class="card form-card">
                <form id="plantForm">
                    <div class="upload-area" id="uploadArea">

                        <label class="label-caps">PLANT REPRESENTATION</label>
                        <div class="upload-zone" id="uploadZone">
                            <div class="upload-icon">
                                <span class="material-symbols-outlined">cloud_upload</span>
                            </div>
                            <p class="upload-text">Click or drag plant image here</p>
                            <p class="upload-hint">High-resolution JPEG or PNG (Max 10MB)</p>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="label-caps">PLANT NAME</label>
                            <input type="text" placeholder="e.g. Emerald Spinach" class="input-field">
                        </div>
                        <div class="form-group">
                            <label class="label-caps">SCIENTIFIC NAME</label>
                            <input type="text" placeholder="e.g. Spinacia oleracea" class="input-field italic">
                        </div>
                    </div>

                    <div class="form-group full-width">
                        <label class="label-caps">PLANT DESCRIPTION</label>
                        <textarea placeholder="Provide a brief overview of the plant variety and its characteristics..." class="textarea-field" rows="3"></textarea>
                    </div>

                    <div class="form-group full-width">
                        <label class="label-caps">GENERAL CARE INSTRUCTIONS</label>
                        <textarea placeholder="Detail the watering, sunlight, and fertilization requirements..." class="textarea-field" rows="4"></textarea>
                    </div>

                    <div class="form-group full-width">
                        <label class="label-caps">COMMON DISEASES & PESTS</label>
                        <div class="tags-input-container">
                            <span class="tag">Downy Mildew <button type="button"><span class="material-symbols-outlined">close</span></button></span>
                            <span class="tag">Aphids <button type="button"><span class="material-symbols-outlined">close</span></button></span>
                            <input type="text" placeholder="Type and press enter..." class="tag-inner-input">
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="button" class="btn btn-outline">Cancel</button>
                        <button type="submit" class="btn btn-primary">
                            <span class="material-symbols-outlined">save</span> Save Plant
                        </button>
                    </div>
                </form>
            </div>

            <div class="bento-grid">
                <div class="bento-card ai-card">
                    <span class="material-symbols-outlined icon-ai">auto_awesome</span>
                    <h4>AI Analysis</h4>
                    <p>Our engine will automatically optimize soil moisture targets based on the scientific name.</p>
                </div>
                <div class="bento-card tip-card">
                    <div class="tip-image">
                        <img src="https://images.unsplash.com/photo-1523348837708-15d4a09cfac2?auto=format&fit=crop&w=200&q=80" alt="Spinach">
                    </div>
                    <div class="tip-content">
                        <span class="tip-label">PRECISION TIP</span>
                        <h5>Verify taxonomic nomenclature</h5>
                        <p>Using exact scientific names ensures the most accurate weather-based growth predictions for your specific region.</p>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>