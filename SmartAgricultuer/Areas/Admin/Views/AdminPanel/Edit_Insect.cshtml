@model SmartAgricultuer.ViewModelsAdmin.InsectFormViewModel

@{
    ViewData["Title"] = "Edit Insect";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/DS/css/Add Insect.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/DS/js/Edit_Insect.js" asp-append-version="true"></script>
}

<main class="main-profile-content">
    <div class="add-insect-container">

        <header class="page-header">
            <h1>Edit Insect: @Model.Name</h1>
            <p>Update insect information and affected plants to refresh the registry.</p>
        </header>

        <form id="insectForm" class="form-card">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" value="@Model.Id" />

            <div class="form-body">
                <div class="grid-2">
                    <div class="input-group">
                        <label>Insect Name</label>
                        <input type="text" name="Name" id="insectName" value="@Model.Name" placeholder="e.g. Aphid" required>
                    </div>
                    <div class="input-group">
                        <label>Scientific Name</label>
                        <input type="text" name="ScientificName" id="sciName" class="italic" value="@Model.ScientificName" placeholder="e.g. Aphidoidea">
                    </div>
                </div>

                <div class="input-group">
                    <label>Insect Status</label>
                    <div class="status-grid">
                        <label class="status-option harmful">
                            <input type="radio" name="Status" value="Harmful" @(Model.Status == "Harmful" ? "checked" : "") required>
                            <div class="status-info">
                                <span class="title">Harmful</span>
                                <span class="desc">Immediate threat</span>
                            </div>
                        </label>
                        <label class="status-option controlled">
                            <input type="radio" name="Status" value="Beneficial" @(Model.Status == "Beneficial" ? "checked" : "")>
                            <div class="status-info">
                                <span class="title">Beneficial</span>
                                <span class="desc">Helpful ecosystem partner</span>
                            </div>
                        </label>
                    </div>
                </div>

                <div class="input-group input-group-relative" id="affectedPlantsSection">
                    <label>Affected Plants</label>
                    <div class="tag-container" id="tagContainer">
                        @if (Model.AffectedPlants != null)
                        {
                            foreach (var plant in Model.AffectedPlants)
                            {
                                <div class="tag">
                                    @plant
                                    <span class="remove-tag">×</span>
                                </div>
                                @* تم حذف الـ input الـ hidden من هنا لمنع التضارب *@
                            }
                        }
                        <input type="text" id="plantInput" placeholder="Add plant...">
                    </div>
                    <div id="autocompleteList" class="autocomplete-suggestions hidden"></div>
                </div>

                <div class="input-group" id="damageDescSection">
                    <label>Damage Description</label>
                    <textarea name="DamageDescription"
                              id="damageDesc"
                              rows="3"
                              placeholder="Describe the typical damage caused...">@Model.DamageDescription</textarea>
                </div>

                <div class="input-group">
                    <label>Prevention Method</label>
                    <textarea name="PreventionMethod"
                              id="prevention"
                              rows="3"
                              placeholder="List recommended prevention measures...">@Model.PreventionMethod</textarea>
                </div>

                <div class="input-group">
                    <label>Insect Photo</label>
                    <div class="upload-box" id="dropZone">
                        <input type="file" name="ImageFile" id="fileInput" accept="image/*" hidden>

                        @if (!string.IsNullOrEmpty(Model.ImageBase64))
                        {
                            <input type="hidden" name="ExistingImage" value="@Model.ImageBase64" />
                            <img id="imagePreview"
                                 src="~/@Model.ImageBase64"
                                 class="preview-img"
                                 alt="Preview">
                        }
                        else
                        {
                            <div class="upload-content" id="uploadContent">
                                <span class="material-symbols-outlined upload-icon">cloud_upload</span>
                                <p class="upload-text">Click to upload or drag and drop</p>
                                <p class="upload-hint">PNG, JPG or WEBP (MAX. 5MB)</p>
                            </div>

                            <img id="imagePreview" class="preview-img hidden" alt="Preview">
                        }
                    </div>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn-cancel" id="cancelBtn" onclick="window.location.href='/Admin/AdminPanel/Insects'">Cancel</button>
                    <button type="button" class="btn-save" id="saveBtn">
                        <span class="material-symbols-outlined">save</span>
                        Save Changes
                    </button>
                </div>
            </div>
        </form>
        <div class="guidance-footer">
            <span class="material-symbols-outlined">info</span>
            <div>
                <strong>Data Accuracy</strong>
                <p>Newly added insects will be cross-referenced with the Global Agronomy Database before public registry update.</p>
            </div>
        </div>
    </div>
</main>