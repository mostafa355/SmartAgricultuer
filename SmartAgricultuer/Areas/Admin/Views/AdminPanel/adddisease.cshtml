@{
    ViewData["Title"] = "Add Insect Page";
}
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}
@section Styles {
    <link rel="stylesheet" href="~/DS/css/adddisease.css" asp-append-version="true" />
}
@section Scripts {
    <script src="~/DS/js/adddisease.js" asp-append-version="true"></script>
}
<main class="main-content">


    <div class="container">
        <div class="form-header">
            <h1>Add New Disease</h1>
            <p>Enter disease information and prevention methods</p>
        </div>

        <div class="card">
            <form id="diseaseForm">
                <div class="grid-2">
                    <div class="form-group">
                        <label>DISEASE NAME</label>
                        <input type="text" placeholder="e.g. Tomato Late Blight">
                    </div>
                    <div class="form-group">
                        <label>PLANT TYPE</label>
                        <select>
                            <option value="" disabled selected>Select plant type</option>
                            <option>Vegetables</option>
                            <option>Fruits</option>
                            <option>Grains</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>VISUAL EVIDENCE</label>
                    <div class="upload-area" id="uploadArea">
                        <div class="upload-icon">
                            <i class="fa-solid fa-cloud-arrow-up"></i>
                        </div>
                        <p class="upload-text">Click to upload or drag and drop</p>
                        <p class="upload-hint">High-res JPEG or PNG (Max 10MB)</p>
                        <input type="file" id="fileInput" hidden>
                    </div>
                </div>

                <div class="form-group">
                    <label>SYMPTOMS</label>
                    <textarea rows="3" placeholder="Describe the physical manifestations on the plant..."></textarea>
                </div>

                <div class="grid-2">
                    <div class="form-group">
                        <label>CAUSES</label>
                        <textarea rows="3" placeholder="Fungal, bacterial, or environmental factors..."></textarea>
                    </div>
                    <div class="form-group">
                        <label>PREVENTION METHODS</label>
                        <textarea rows="3" placeholder="List preventive measures and treatments..."></textarea>
                    </div>
                </div>

                <div class="status-section">
                    <label>DETECTION STATUS</label>
                    <div class="status-options">
                        <label class="status-card">
                            <input type="radio" name="status" value="low">
                            <div class="status-content">
                                <span class="dot dot-low"></span> Low Severity
                            </div>
                        </label>
                        <label class="status-card">
                            <input type="radio" name="status" value="moderate" checked>
                            <div class="status-content">
                                <span class="dot dot-mod"></span> Moderate Severity
                            </div>
                        </label>
                        <label class="status-card">
                            <input type="radio" name="status" value="critical">
                            <div class="status-content">
                                <span class="dot dot-crit"></span> Critical Severity
                            </div>
                        </label>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn-cancel">Cancel</button>

                    <button type="submit" class="btn-save">
                        <span class="material-symbols-outlined">save</span>
                        Save Disease
                    </button>
                </div>
            </form>
        </div>

        <div class="info-grid">
            <div class="info-item">
                <div class="info-icon"><i class="fa-regular fa-lightbulb"></i></div>
                <div>
                    <h3>Best Practice</h3>
                    <p>Upload images from multiple angles for better AI detection accuracy.</p>
                </div>
            </div>
            <div class="info-item">
                <div class="info-icon"><i class="fa-solid fa-circle-check"></i></div>
                <div>
                    <h3>Global Database</h3>
                    <p>Your entries contribute to a shared agronomist knowledge pool.</p>
                </div>
            </div>
            <div class="info-item">
                <div class="info-icon"><i class="fa-solid fa-rotate"></i></div>
                <div>
                    <h3>Auto-Sync</h3>
                    <p>Data is synced across all field devices instantly after saving.</p>
                </div>
            </div>
        </div>
    </div>
</main>
