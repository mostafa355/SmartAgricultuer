@model IEnumerable<SmartAgricultuer.ViewModels.InsectTableViewModel>

@{
    ViewData["Title"] = "Insects Page";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/DS/css/formtable.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/DS/js/Insects.js" asp-append-version="true"></script>
}

<main class="main-content">
    <div class="content-container">

        <div class="page-header">
            <div class="page-title">
                <h1>Insects Database</h1>
                <p>Manage harmful insects affecting plants</p>
            </div>
            <a asp-area="Admin" asp-controller="AdminPanel" asp-action="Add_Insects">
                <button class="btn-add">
                    <span class="material-symbols-outlined">add_circle</span>
                    Add Insect
                </button>
            </a>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon-wrapper red-bg">
                    <span class="material-symbols-outlined">report_problem</span>
                </div>
                <div class="stat-info">
                    <span class="stat-label">CRITICAL ALERTS (HARMFUL)</span>
                    <span class="stat-value" style="color: #dc2626;">@ViewBag.CriticalAlerts</span>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon-wrapper green-bg">
                    <span class="material-symbols-outlined">eco</span>
                </div>
                <div class="stat-info">
                    <span class="stat-label">BENEFICIAL SPECIES</span>
                    <span class="stat-value" style="color: #16a34a;">@ViewBag.BeneficialSpecies</span>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon-wrapper blue-bg">
                    <span class="material-symbols-outlined">visibility</span>
                </div>
                <div class="stat-info">
                    <span class="stat-label">MONITORED SPECIES</span>
                    <span class="stat-value" style="color: #2563eb;">@ViewBag.TotalSpecies</span>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon-wrapper purple-bg">
                    <span class="material-symbols-outlined">bug_report</span>
                </div>
                <div class="stat-info">
                    <span class="stat-label">TOTAL SPECIES</span>
                    <span class="stat-value" style="color: #9333ea;">@ViewBag.TotalSpecies</span>
                </div>
            </div>
        </div>

        <div class="search-container">
            <div class="search-box">
                <span class="material-symbols-outlined search-icon">search</span>
                <input type="text" id="insectSearch" onkeyup="filterInsectsTable()" placeholder="Search by Insects name, scientific name, or ID...">
            </div>
        </div>

        <div class="table-card">
            <div class="table-responsive">
                <table id="insectsTable">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Insect Name</th>
                            <th>Scientific Name</th>
                            <th>Affected Plants</th>
                            <th>Damage Type</th>
                            <th>Status</th>
                            <th class="text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" style="text-align:center; color:#64748b; padding: 24px;">No insects found in database</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                // تحديد كلاس الحالة والـ Badge بشكل ديناميكي بناءً على داتا الـ SQL الحقيقية
                                string statusBadgeClass = "status-controlled";
                                if (item.Status == "Harmful")
                                {
                                    statusBadgeClass = "status-harmful";
                                }
                                else if (item.Status == "Beneficial")
                                {
                                    statusBadgeClass = "status-controlled"; // لون أخضر مريح
                                }

                                <tr>
                                    <td style="color: #94a3b8; font-family: monospace;">#INS-@item.Id.ToString("D4")</td>
                                    <td>
                                        <div class="insect-cell">
                                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                                            {
                                                <img src="@Url.Content("~/" + item.ImageUrl)" class="table-thumb-img" alt="@item.Name">
                                            }
                                            else
                                            {
                                                <div class="table-thumb-placeholder">🪲</div>
                                            }
                                            <span style="font-weight: 600; color: #002d1c;">@item.Name</span>
                                        </div>
                                    </td>
                                    <td class="scientific-name" style="font-style: italic; color: #475569;">@item.ScientificName</td>
                                    <td>
                                        <span style="color: #334155;">@item.AffectedPlants</span>
                                    </td>
                                    <td style="max-width: 250px; color: #475569;" title="@item.DamageType">
                                        @(item.DamageType.Length > 50 ? item.DamageType.Substring(0, 50) + "..." : item.DamageType)
                                    </td>
                                    <td>
                                        <span class="status-badge @statusBadgeClass">
                                            <span class="dot"></span> @item.Status
                                        </span>
                                    </td>
                                    <td class="actions-cell">
                                        <div class="action-menu">
                                            <button class="btn-action-trigger" onclick="toggleDropdown(event, 'dropdown-@item.Id')">
                                                <span class="material-symbols-outlined">more_vert</span>
                                            </button>
                                            <div class="dropdown" id="dropdown-@item.Id" style="display:none;">
                                                <button type="button" onclick="editInsect('@item.Id')">Edit</button>
                                                <button type="button" class="btn-delete" onclick="deleteInsect('@item.Id')">Delete</button>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="table-footer">
                <span id="entryCount">Loading entries...</span>

                <div class="pagination" id="paginationWrapper">
                </div>
            </div>
        </div>

        <div class="bento-grid">
            <div class="card card-white">
                <div class="card-header-icon text-secondary">
                    <span class="material-symbols-outlined">monitoring</span>
                    <span>OUTBREAK RISK</span>
                </div>
                <h3>High Activity</h3>
                <p>Predicted increase in Potato Beetle activity due to rising soil temperatures.</p>
                <a href="#" class="link-arrow">View Hotspot Map →</a>
            </div>

            <div class="card card-green">
                <div class="card-header-icon text-emerald">
                    <span class="material-symbols-outlined">shield</span>
                    <span>PREVENTION TIP</span>
                </div>
                <h3>Biological Control</h3>
                <p>Introduce natural predators like Ladybugs to manage Aphid populations.</p>
                <button class="btn-outline-white">Request Resource Delivery</button>
            </div>

            <div class="card card-white relative">
                <div class="card-header-icon text-slate">
                    <span class="material-symbols-outlined">hub</span>
                    <span>GLOBAL DATABASE</span>
                </div>
                <h3>1,200+ Species</h3>
                <p>Our AI model has expanded to identify more regional variants of tropical insects.</p>
                <span class="material-symbols-outlined bg-icon-watermark">bug_report</span>
            </div>
        </div>
    </div>
</main>