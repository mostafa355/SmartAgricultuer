@{
    ViewData["Title"] = "Home Page";
}
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}
@section Styles {

    <link rel="stylesheet" href="~/DS/css/analses.css" asp-append-version="true" >
}
@section Scripts {
    <script src="~/DS/js/analses.js" asp-append-version="true"></script>
}
<div >
    <div class="topbar">

        <div class="topbar-title-area">
            <h2 style="font-size: 20px; font-weight: 800; color: var(--green-dark);">Analytics Insights</h2>
        </div>

        <div class="topbar-right">

       

      

            <div class="profile-info">
                <strong>Dr. Aris Thorne</strong>
                <span>Senior Agronomist</span>
            </div>
            <div class="avatar">AT</div>

        </div>
    </div>



    <div class="content">

      
     


      
        <div class="stats-grid">

   
            <div class="stat-card">
                <div class="stat-top">
                    <div class="stat-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#14532d" stroke-width="2" width="20" height="20">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                            <circle cx="9" cy="7" r="4" />
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                        </svg>
                    </div>
                    <span class="stat-badge badge-green">+12%</span>
                </div>
                <div class="stat-label">TOTAL USERS</div>
                <div class="stat-value">1,240</div>
            </div>

            <!-- Total Uploads -->
            <div class="stat-card">
                <div class="stat-top">
                    <div class="stat-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#14532d" stroke-width="2" width="20" height="20">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                            <polyline points="14 2 14 8 20 8" />
                            <line x1="16" y1="13" x2="8" y2="13" />
                            <line x1="16" y1="17" x2="8" y2="17" />
                        </svg>
                    </div>
                    <span class="stat-badge badge-green">+8.4%</span>
                </div>
                <div class="stat-label">TOTAL UPLOADS</div>
                <div class="stat-value">45.2k</div>
            </div>

            <div class="stat-card">
                <div class="stat-top">
                    <div class="stat-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#14532d" stroke-width="2" width="20" height="20">
                            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                        </svg>
                    </div>
                    <span class="stat-badge badge-green">+15%</span>
                </div>
                <div class="stat-label">TOTAL ANALYSES</div>
                <div class="stat-value">38.1k</div>
            </div>


            <div class="stat-card">
                <div class="stat-top">
                    <div class="stat-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" width="20" height="20">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="12" />
                            <line x1="12" y1="16" x2="12.01" y2="16" />
                        </svg>
                    </div>
                    <span class="stat-badge badge-green">+2%</span>
                </div>
                <div class="stat-label">DISEASED PLANTS</div>
                <div class="stat-value">5,402</div>
            </div>

            <div class="stat-card">
                <div class="stat-top">
                    <div class="stat-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#14532d" stroke-width="2" width="20" height="20">
                            <path d="M12 22V12M12 12C12 12 7 10 7 5a5 5 0 0 1 10 0c0 5-5 7-5 7z" />
                        </svg>
                    </div>
                    <span class="stat-badge badge-green">+18%</span>
                </div>
                <div class="stat-label">HEALTHY PLANTS</div>
                <div class="stat-value">29.8k</div>
            </div>

        
            <div class="stat-card">
                <div class="stat-top">
                    <div class="stat-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" width="20" height="20">
                            <path d="M8 3H5a2 2 0 0 0-2 2v3M21 8V5a2 2 0 0 0-2-2h-3M3 16v3a2 2 0 0 0 2 2h3M16 21h3a2 2 0 0 0 2-2v-3" />
                        </svg>
                    </div>
                    <span class="stat-badge badge-red">-4%</span>
                </div>
                <div class="stat-label">INSECT DETECTIONS</div>
                <div class="stat-value">2,896</div>
            </div>

        </div>


  
        <div class="mid-grid">


            <div class="card">
                <div class="chart-header">
                    <div class="card-title">Daily &amp; Monthly Activity</div>
                    <div class="chart-legend">
                        <div class="legend-item">
                            <div class="legend-dot" style="background:#006d3d"></div> UPLOADS
                        </div>
                        <div class="legend-item">
                            <div class="legend-dot" style="background:#dff3e5"></div> USERS
                        </div>
                    </div>
                </div>

                <div class="bar-chart">
                    <div class="bar-group">
                        <div class="bars">
                            <div class="bar bar-uploads" style="height:100px"></div>
                            <div class="bar bar-users" style="height:70px"></div>
                        </div>
                        <div class="bar-label">MON</div>
                    </div>
                    <div class="bar-group">
                        <div class="bars">
                            <div class="bar bar-uploads" style="height:140px"></div>
                            <div class="bar bar-users" style="height:90px"></div>
                        </div>
                        <div class="bar-label">TUE</div>
                    </div>
                    <div class="bar-group">
                        <div class="bars">
                            <div class="bar bar-uploads" style="height:110px"></div>
                            <div class="bar bar-users" style="height:75px"></div>
                        </div>
                        <div class="bar-label">WED</div>
                    </div>
                    <div class="bar-group">
                        <div class="bars">
                            <div class="bar bar-uploads" style="height:155px"></div>
                            <div class="bar bar-users" style="height:100px"></div>
                        </div>
                        <div class="bar-label">THU</div>
                    </div>
                    <div class="bar-group">
                        <div class="bars">
                            <div class="bar bar-uploads" style="height:130px"></div>
                            <div class="bar bar-users" style="height:80px"></div>
                        </div>
                        <div class="bar-label">FRI</div>
                    </div>
                    <div class="bar-group">
                        <div class="bars">
                            <div class="bar bar-uploads" style="height:185px"></div>
                            <div class="bar bar-users" style="height:120px"></div>
                        </div>
                        <div class="bar-label">SAT</div>
                    </div>
                    <div class="bar-group">
                        <div class="bars">
                            <div class="bar bar-uploads" style="height:200px"></div>
                            <div class="bar bar-users" style="height:135px"></div>
                        </div>
                        <div class="bar-label">SUN</div>
                    </div>
                </div>
            </div>

      
            <div class="card">
                <div class="card-title">Plant Health Distribution</div>
                <div class="donut-wrap">
                    <div class="donut-container">
                        <svg class="donut-svg" viewBox="0 0 120 120">
                            <!-- Track -->
                            <circle cx="60" cy="60" r="50" fill="none" stroke="#e5e7eb" stroke-width="18" />
                            <!-- Healthy 75% -->
                            <circle cx="60" cy="60" r="50" fill="none" stroke="#006d3d" stroke-width="18"
                                    stroke-dasharray="235.6 314.2" stroke-dashoffset="0" stroke-linecap="round" />
                            <!-- Diseased 15% -->
                            <circle cx="60" cy="60" r="50" fill="none" stroke="#ef4444" stroke-width="18"
                                    stroke-dasharray="47.1 314.2" stroke-dashoffset="-235.6" stroke-linecap="round" />
                            <!-- Insect 10% -->
                            <circle cx="60" cy="60" r="50" fill="none" stroke="#f59e0b" stroke-width="18"
                                    stroke-dasharray="31.4 314.2" stroke-dashoffset="-282.7" stroke-linecap="round" />
                        </svg>
                        <div class="donut-inner">
                            <h3>38.1k</h3>
                            <p>TOTAL ANALYZED</p>
                        </div>
                    </div>

                    <div class="donut-legend">
                        <div class="donut-row">
                            <div class="legend-label">
                                <div class="legend-circle" style="background:#006d3d"></div> Healthy
                            </div>
                            <span class="donut-pct">75%</span>
                        </div>
                        <div class="donut-row">
                            <div class="legend-label">
                                <div class="legend-circle" style="background:#ef4444"></div> Diseased
                            </div>
                            <span class="donut-pct">15%</span>
                        </div>
                        <div class="donut-row">
                            <div class="legend-label">
                                <div class="legend-circle" style="background:#f59e0b"></div> Insect Detected
                            </div>
                            <span class="donut-pct">10%</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="bottom-grid">

            <div class="card">
                <div class="card-title">Most Detected Diseases</div>
                <div class="disease-row">

                    <div class="disease-item">
                        <div class="disease-header">
                            <span>Early Blight</span>
                            <span class="disease-count">1,245 cases</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width:85%; background:#ef4444"></div>
                        </div>
                    </div>

                    <div class="disease-item">
                        <div class="disease-header">
                            <span>Tomato Mosaic Virus</span>
                            <span class="disease-count">942 cases</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width:65%; background:#ef4444"></div>
                        </div>
                    </div>

                    <div class="disease-item">
                        <div class="disease-header">
                            <span>Leaf Mold</span>
                            <span class="disease-count">512 cases</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width:40%; background:#f59e0b"></div>
                        </div>
                    </div>

                    <div class="disease-item">
                        <div class="disease-header">
                            <span>Bacterial Spot</span>
                            <span class="disease-count">308 cases</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width:25%; background:#fca5a5"></div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="card">
                <div class="card-title">Common Insects</div>

                <div class="insect-item">
                    <div class="insect-icon">🐛</div>
                    <div class="insect-info">
                        <div class="insect-name">Green Peach Aphid</div>
                        <div class="insect-affects">Affects Tomatoes, Potatoes</div>
                    </div>
                    <div class="insect-count">
                        <div class="insect-num">1.2k</div>
                        <span class="insect-tag tag-invasive">Invasive</span>
                    </div>
                </div>

                <div class="insect-item">
                    <div class="insect-icon">🪲</div>
                    <div class="insect-info">
                        <div class="insect-name">Potato Beetle</div>
                        <div class="insect-affects">Affects Potatoes, Eggplant</div>
                    </div>
                    <div class="insect-count">
                        <div class="insect-num" style="color:#374151">856</div>
                        <span class="insect-tag tag-stable">Stable</span>
                    </div>
                </div>

                <div class="insect-item">
                    <div class="insect-icon">🦗</div>
                    <div class="insect-info">
                        <div class="insect-name">Migratory Locust</div>
                        <div class="insect-affects">Affects Corn, Wheat</div>
                    </div>
                    <div class="insect-count">
                        <div class="insect-num" style="color:#374151">421</div>
                        <span class="insect-tag tag-low">Low Risk</span>
                    </div>
                </div>

            </div>

            <div style="display:flex; flex-direction:column; gap:18px;">

                <div class="confidence-card">
                    <div class="confidence-header">
                        <h3>Model Confidence</h3>
                        <div class="lightning">⚡</div>
                    </div>
                    <div class="conf-pct">
                        <span>94%</span> <small>Global Avg</small>
                    </div>
                    <div class="conf-label">ACCURACY</div>
                    <div class="acc-row">
                        <span>ACCURACY</span>
                        <span>98%</span>
                    </div>
                    <div class="acc-bar">
                        <div class="acc-fill"></div>
                    </div>
                    <div class="conf-plus">+</div>
                </div>

                <div class="card">
                    <div class="card-title" style="font-size:13px;">Top Analyzed Plants</div>
                    <div class="plants-grid">
                        <div class="plant-card"><small>TOMATO</small><strong>42%</strong></div>
                        <div class="plant-card"><small>POTATO</small><strong>28%</strong></div>
                        <div class="plant-card"><small>APPLE</small> <strong>18%</strong></div>
                        <div class="plant-card"><small>CORN</small>  <strong>12%</strong></div>
                    </div>
                </div>

            </div>

        </div>


        <div class="last-grid">

            <div class="card">
                <div class="card-title">Critical Alerts</div>

                <div class="alert-item alert-red">
                    <div class="alert-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2">
                            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                            <line x1="12" y1="9" x2="12" y2="13" />
                            <line x1="12" y1="17" x2="12.01" y2="17" />
                        </svg>
                        <div>
                            <div class="alert-title" style="color:#dc2626">
                                Tomato Yellow Curl increased by 40% this week
                            </div>
                            <div class="alert-desc">Affected regions: Southern Sector, Plot 4B</div>
                        </div>
                    </div>
                </div>

                <div class="alert-item alert-orange">
                    <div class="alert-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="12" />
                            <line x1="12" y1="16" x2="12.01" y2="16" />
                        </svg>
                        <div>
                            <div class="alert-title" style="color:#d97706">
                                High disease activity detected in tomatoes
                            </div>
                            <div class="alert-desc">System recommendation: Immediate copper-based treatment</div>
                        </div>
                    </div>
                </div>

        
            </div>

            <div class="card">
                <div class="table-header">
                    <div class="card-title">Recent Diagnostic Activity</div>

                </div>

                <table class="tbl">
                    <thead>
                        <tr>
                            <th>USER</th>
                            <th>PLANT NAME</th>
                            <th>RESULT</th>
                            <th>CONFIDENCE</th>
                            <th>DATE</th>
                        </tr>
                    </thead>
                    <tbody>

           
                        <tr>
                            <td>
                                <div class="user-cell">
                                    <div class="user-av av-jd">JD</div>
                                    <div class="user-name">John Doe</div>
                                </div>
                            </td>
                            <td>
                                <div class="plant-name">Tomato</div>
                                <div class="plant-sci">Solanum lycopersicum</div>
                            </td>
                            <td><span class="result-badge badge-blight">Early Blight</span></td>
                            <td><span class="conf-val">99.2%</span></td>
                            <td><div class="date-val">Oct 24, 14:32</div></td>
                        </tr>


                        <tr>
                            <td>
                                <div class="user-cell">
                                    <div class="user-av av-as">AS</div>
                                    <div class="user-name">Anna Smith</div>
                                </div>
                            </td>
                            <td>
                                <div class="plant-name">Potato</div>
                                <div class="plant-sci">Solanum tuberosum</div>
                            </td>
                            <td><span class="result-badge badge-healthy">Healthy</span></td>
                            <td><span class="conf-val">98.5%</span></td>
                            <td><div class="date-val">Oct 24, 12:15</div></td>
                        </tr>

      
                        <tr>
                            <td>
                                <div class="user-cell">
                                    <div class="user-av av-mk">MK</div>
                                    <div class="user-name">Mike K.</div>
                                </div>
                            </td>
                            <td>
                                <div class="plant-name">Apple</div>
                                <div class="plant-sci">Malus domestica</div>
                            </td>
                            <td><span class="result-badge badge-spider">Spider Mites</span></td>
                            <td><span class="conf-val">92.1%</span></td>
                            <td><div class="date-val">Oct 23, 18:04</div></td>
                        </tr>

                    </tbody>
                </table>
            </div>

        </div>

    </div>
</div>